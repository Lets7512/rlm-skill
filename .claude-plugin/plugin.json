{
  "name": "rlm",
  "description": "RLM (Recursive Language Model) \u2014 large-context analysis via REPL pattern. Based on MIT's RLM paper (arXiv:2512.24601). Automatically detects large files and suggests the optimal RLM pattern.",
  "version": "0.4.1",
  "author": {
    "name": "Omar"
  },
  "homepage": "https://github.com/lets7512/rlm-skill",
  "repository": "https://github.com/lets7512/rlm-skill",
  "license": "MIT",
  "keywords": [
    "rlm",
    "large-context",
    "repl",
    "data-analysis",
    "token-savings",
    "context-window"
  ],
  "skills": "./skills/",
  "mcpServers": {
    "rlm": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/mcp/server.mjs"
      ]
    }
  }
}
